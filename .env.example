# Backend / AI
CLAUDE_SONNET_API_KEY={Anthropic Claude API key}
CLAUDE_SONNET_MODEL=claude-sonnet-4-5-20250929
CLAUDE_SONNET_BASE_URL=https://api.anthropic.com/v1
CLAUDE_SONNET_ENABLED=true
CLAUDE_SONNET_TIMEOUT_SECONDS=30
CLAUDE_SONNET_MAX_TOKENS=8192
CLAUDE_SONNET_MAX_ATTEMPTS=2
OPENROUTER_GEMINI_API_KEY={OpenRouter API key for Gemini}
OPENROUTER_API_KEY={OpenRouter API key fallback alias}
OPENROUTER_GEMINI_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODELS=google/gemini-2.5-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FALLBACK_ENABLED=true
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_MAX_ATTEMPTS=2
GOOGLE_API_KEY={Google AI Studio API key}
GEMINI_FALLBACK_API_KEYS={Comma-separated fallback Google AI Studio API keys}
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_MAX_ATTEMPTS=2
GEMINI_MAX_RETRY_DELAY_SECONDS=8
ZAI_API_KEY={ZAI api key}
ZAI_FALLBACK_ENABLED=true
ZAI_BASE_URL=https://api.ilmu.ai/v1
ZAI_MODEL=ilmu-glm-5.1
GLM_MODEL=ilmu-glm-5.1
ZAI_TIMEOUT_SECONDS=30
ZAI_MAX_TOKENS=8192
ZAI_MAX_ATTEMPTS=2
SCOUT_SOURCE_FILE=backend/data/scout_sources.json
SCOUT_RESPECT_ROBOTS_TXT=true
SCOUT_REQUEST_DELAY_SECONDS=1.0
SCOUT_MAX_PAGES_PER_SOURCE=12
SCOUT_MAX_LINKS_PER_PAGE=10

# Optional Vertex / Google Cloud metadata
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Next.js frontend
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AI_SANDBOX_BASE_URL=http://localhost:8001

# Firebase web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
